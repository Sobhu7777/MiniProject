   "source": [
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "Xw_train, Xw_test, yw_train, yw_test = train_test_split(\n",
    "    X_wind,\n",
    "    y_wind,\n",
    "    test_size=0.2,\n",
    "    random_state=42,\n",
    "    stratify=y_wind\n",
    ")"
   ]
