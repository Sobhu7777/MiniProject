    "def interactive_location_selection():\n",
    "    \n",
    "    # ---- Step 1: Show Regions ----\n",
    "    regions = get_regions()\n",
    "    print(\"Available Regions:\")\n",
    "    for i, r in enumerate(regions, 1):\n",
