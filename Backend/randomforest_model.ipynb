    "def risk_level(prob):\n",
    "    if prob < 0.3:\n",
    "        return \"LOW\"\n",
    "    elif prob < 0.6:\n",
    "        return \"MODERATE\"\n",
    "    else:\n",
    "        return \"HIGH\""
   ]
  },
