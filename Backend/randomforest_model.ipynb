   "source": [
    "# =====================================\n",
    "# WINDSTORM MODEL SECTION (MONTHLY)\n",
    "# =====================================\n",
    "\n",
    "df_wind = pd.read_csv(\"windstorm.csv\")\n",
    "\n",
    "df_wind.rename(columns={\n",
    "    \"Month\": \"month\",\n",
    "    \"Place\": \"place\"\n",
    "}, inplace=True)\n",
    "\n",
    "wind_features = [\n",
    "    \"month\",\n",
    "    \"WindSpeed_km_per_hr\",\n",
    "    \"Temperature_C\",\n",
    "    \"Humidity_percent\",\n",
    "    \"WindSpeed_3day_cum\"\n",
    "]\n",
    "\n",
    "X_wind = df_wind[wind_features].copy()\n",
    "y_wind = df_wind[\"Wind_Disaster_Occurred\"]"
   ]
  },
