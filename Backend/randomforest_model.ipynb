    "def adjust_probability(base_prob, api_rainfall, historical_daily_baseline):\n",
    "    \n",
    "    ratio = api_rainfall / historical_daily_baseline\n",
    "    \n",
    "    if ratio < 0.7:\n",
    "        adjustment = -0.05\n",
    "    elif ratio < 1.3:\n",
    "        adjustment = 0\n",
    "    elif ratio < 2:\n",
    "        adjustment = 0.05\n",
    "    elif ratio < 3:\n",
    "        adjustment = 0.10\n",
    "    else:\n",
    "        adjustment = 0.15\n",
    "\n",
    "    new_prob = base_prob + adjustment\n",
    "    new_prob = max(0, min(new_prob, 1))\n",
    "    \n",
    "    return new_prob"
   ]
  },
